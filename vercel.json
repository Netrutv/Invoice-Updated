{
    "version": 2,
    "outputDirectory": "public",
    "rewrites": [
        {
            "source": "/api/invoices/:id",
            "destination": "/api/invoices/[id]"
        },
        {
            "source": "/api/invoices",
            "destination": "/api/invoices"
        },
        {
            "source": "/api/profile",
            "destination": "/api/profile"
        },
        {
            "source": "/api/stats",
            "destination": "/api/stats"
        }
    ]
}